# ---------------------------------------------
# Unity generated / machine-specific folders
# (rebuilt automatically — never commit these)
# ---------------------------------------------
/[Ll]ibrary/
/[Tt]emp/
/[Oo]bj/
/[Bb]uild/
/[Bb]uilds/
/[Ll]ogs/
/[Uu]serSettings/
/[Mm]emoryCaptures/
/[Rr]ecordings/

# Asset meta data should only be ignored when the corresponding asset is also ignored
!/[Aa]ssets/**/*.meta

# Autogenerated Unity crash / package caches
/[Aa]ssets/[Aa]ddressable[Aa]ssets[Dd]ata/*/*.bin*
/[Aa]ssets/[Ss]treamingAssets/aa.meta
/[Aa]ssets/[Ss]treamingAssets/aa/*

# ---------------------------------------------
# Visual Studio / Rider / VS Code generated files
# (IDE project files — Unity regenerates these)
# ---------------------------------------------
.vs/
.vscode/
.idea/
ExportedObj/
*.csproj
*.unityproj
*.sln
*.slnx
*.suo
*.tmp
*.user
*.userprefs
*.pidb
*.booproj
*.svd
*.pdb
*.mdb
*.opendb
*.VC.db

# ---------------------------------------------
# OS generated files
# ---------------------------------------------
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
desktop.ini

# ---------------------------------------------
# Unity build outputs & crash reports
# ---------------------------------------------
sysinfo.txt
*.apk
*.aab
*.unitypackage
*.app
crashlytics-build.properties
/[Aa]ssets/[Pp]lugins/[Ee]ditor/JetBrains*

# Local packages cache
/[Pp]ackages/*/[Cc]hangelog.md.meta
